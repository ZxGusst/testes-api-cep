{
  "info": {
    "_postman_id": "a1b2c3d4-e5f6-7890-abcd-ef1234567890",
    "name": "CEP API - Testes Automatizados",
    "description": "Testes automatizados para a BrasilAPI - endpoint de consulta de CEP.\nSem autenticação, sem token — 100% gratuito.\n\nValida: status HTTP, estrutura do corpo JSON e tempo de resposta.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "01 - Consultas Válidas",
      "item": [
        {
          "name": "CT-01 | GET CEP Válido - Retorna 200",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('CT-01 | Status deve ser 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('CT-01 | Tempo de resposta abaixo de 3000ms', function () {",
                  "    pm.expect(pm.response.responseTime).to.be.below(3000);",
                  "});",
                  "",
                  "pm.test('CT-01 | Content-Type é application/json', function () {",
                  "    pm.expect(pm.response.headers.get('Content-Type')).to.include('application/json');",
                  "});",
                  "",
                  "pm.test('CT-01 | Corpo contém campo cep', function () {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json).to.have.property('cep');",
                  "});",
                  "",
                  "pm.test('CT-01 | Corpo contém campo state', function () {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json).to.have.property('state');",
                  "    pm.expect(json.state).to.be.a('string').and.not.empty;",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/{{cep_valido}}",
              "host": ["{{base_url}}"],
              "path": ["{{cep_valido}}"]
            },
            "description": "Consulta um CEP válido (Praça da Sé - SP).\nEspera-se status 200 e campos cep, state, city no corpo."
          },
          "response": []
        },
        {
